{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
  },
  "include": ["src", "Swagger/swagger.js",],
  "exclude": ["node_modules"],
  "lib": ["es2015"],
  "types": ["node", "express"]
}